# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# ModMed sandbox credentials (per-practice in production, env vars for sandbox)
MODMED_FIRM_URL_PREFIX=orthopmsandbox499
MODMED_USERNAME=your-sandbox-username
MODMED_PASSWORD=your-sandbox-password
MODMED_API_KEY=your-sandbox-api-key
MODMED_AUTH_BASE_URL=https://stage.ema-api.com/ema-dev

# PHI Encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be different from Supabase keys. Production: use AWS Secrets Manager or Vercel encrypted env vars.
PHI_ENCRYPTION_KEY=your-64-char-hex-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
